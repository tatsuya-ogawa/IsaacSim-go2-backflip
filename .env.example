ISAAC_LAB_IMAGE=nvcr.io/nvidia/isaac-lab:2.3.2
BACKFLIP_IMAGE=go2-backflip-isaaclab:latest
RSL_RL_VERSION=5.0.1

# Set these to Y only after accepting the NVIDIA Isaac Sim / Isaac Lab terms.
ACCEPT_EULA=
PRIVACY_CONSENT=

NUM_ENVS=4096
MAX_ITERATIONS=1000
TASK_NAME=Unitree-Go2-Backflip-Isaac-v0
RESUME=0
LOAD_RUN=
CHECKPOINT=
POLICY_PATH=
PLAY_NUM_ENVS=1
GO2_BACKFLIP_USD_PATH=
GO2_BACKFLIP_RANDOMIZE_CONTROLS=1
GO2_BACKFLIP_RANDOMIZE_RIGIDS=1
BACKFLIP_ACTION_STD_MIN=0.05
BACKFLIP_ACTION_STD_MAX=1.0
VIDEO_RENDERING_MODE=quality
